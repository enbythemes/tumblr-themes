    <style>
        * {
            box-sizing: border-box;
        }
        
        :root {
            --Font-Family: {text:google font};
            --Font-Size: {select:font size};
            --Post-Width: {select:post size};
            --Gutter-Size: {select:photoset gutter size};
            --Post-Margin: {text:post margin}px;
            --NPF-Image-Spacing:{select:photoset gutter size};
            --NPF-Caption-Spacing: 1em;
            --ExSmallGap: 0.25em;
            --SmallGap: 0.5em;
            --NormalGap: 1em;
            --LargeGap: 1.5em;
        }
        
        :root, html[data-theme="light"] {
            --Clr-Background: {RGBcolor:light mode background};
            --Clr-Text: {RGBcolor:light mode text};
            --Clr-Header: {RGBcolor:light mode header};
            --Clr-Posts: {RGBcolor:light mode posts};
            --Clr-Borders: {RGBcolor:light mode borders};
            --Clr-Liked: {RGBcolor:light mode liked};
            --Clr-Ac1: {RGBcolor:light mode accent color 1};
            --Clr-Ac2: {RGBcolor:light mode accent color 2};
            --Clr-Ac3: {RGBcolor:light mode accent color 3};
            --Clr-Ac4: {RGBcolor:light mode accent color 4};
            --Clr-Ac5: {RGBcolor:light mode accent color 5};
            --Clr-Ac6: {RGBcolor:light mode accent color 6};
            --Clr-Light-Box: 130,130,130;
            --TumblrControls: invert(1) hue-rotate(180deg);
            --LightOn: none;
            --LightOff: block;
            --ImageFilters: none;
        }
        
        :root, html[data-theme="dark"] {
            --Clr-Background: {RGBcolor:dark mode background};
            --Clr-Text: {RGBcolor:dark mode text};
            --Clr-Header: {RGBcolor:dark mode header};
            --Clr-Posts: {RGBcolor:dark mode posts};
            --Clr-Borders: {RGBcolor:dark mode borders};
            --Clr-Liked: {RGBcolor:dark mode liked};
            --Clr-Ac1: {RGBcolor:dark mode accent color 1};
            --Clr-Ac2: {RGBcolor:dark mode accent color 2};
            --Clr-Ac3: {RGBcolor:dark mode accent color 3};
            --Clr-Ac4: {RGBcolor:dark mode accent color 4};
            --Clr-Ac5: {RGBcolor:dark mode accent color 5};
            --Clr-Ac6: {RGBcolor:dark mode accent color 6};
            --Clr-border-bottom: 1px solid rgba(var(--Clr-Borders),1);-Box: 50,50,50;
            --TumblrControls: none;
            --LightOn: block;
            --LightOff: none;
            --ImageFilters: brightness(0.9) grayscale(15%);
        }
        
        /* TRANSITIONS */
        html.theme-transition,
        html.theme-transition *,
        html.theme-transition *:before,
        html.theme-transition *:after {
            transition: 0s!important;
            transition-delay: 0!important;
        }
        
        a, a:hover, img, button, svg, .ph, div.npf-link-block {
            transition: all 0.4s;
            -webkit-transition: all 0.4s;
            -moz-transition: all 0.4s;
            -ms-transition: all 0.4s;
            -o-transition: all 0.4s;
        }
        
        body {
            margin: 0;
            background: rgba(var(--Clr-Background),1);
            font-family: var(--Font-Family);
            font-size: var(--Font-Size);
            color: rgba(var(--Clr-Text),1);
            line-height: 1.5;
            letter-spacing: 0.025em;
        }
        
        a {
            text-decoration: none;
        }
        
        a:hover {
            color: rgba(var(--Clr-Accent-1),1);
        }
        
        blockquote {
            margin: var(--NormalGap);
            padding-left: var(--NormalGap);
            border-left: 2px solid rgba(var(--Clr-Borders),1);
        }
        
        h1, h2, h3, h4, h5, .blog-title, .text-title, .quote {
            letter-spacing: 0.025em;
        }
        
        h1 {font-size: 1.5em;}
        h2, .text-title {font-size: 1.4em;}
        h3, big, .quote, .npf_quote {font-size: 1.3em;}
        h4, .blog-title {font-size: 1.25em;}
        h5 {font-size: 1.1em;}
        small {font-size: 0.9em;}
        
        p:empty {
            display: none;
        }
        
        ul {list-style-type: circle;}
        
        .ph {
            font-size: 18px;
            vertical-align: middle;
            color: rgba(var(--Clr-Text),1);
        }
        
        /* SHORTHANDS */
        .flex {
            display: flex;
        }
        
        .wrap {
            flex-wrap: wrap;
        }
        
        .align-center {
            align-items: center;
        }
        
        {block:ifDarkModeImageFilters}
        img {filter: var(--ImageFilters);}
        img:hover, aside:hover img, .posts:hover img {filter: none;}
        {/block:ifDarkModeImageFilters}
        
        {block:ifRoundedCorners}
        article.posts, .post-more {
            border-radius: var(--SmallGap);
        }
        
        header {
            border-radius: var(--SmallGap) var(--SmallGap) 0 0;
        }
        
        nav {
            border-radius: 0 0 var(--SmallGap) var(--SmallGap);
        }
        
        {/block:ifRoundedCorners}
        
        /* BUTTONS AND CONTROLS */
        button {
            background: rgba(var(--Clr-Sidebar),1);
            border: 0;
            outline: none;
            padding: var(--SmallGap);
            cursor: pointer;
        }
        
        #theme-controls, #bottom-buttons {
            position: fixed;
            right: var(--NormalGap);
            gap: var(--SmallGap);
            flex-direction: column;
        }
        
        #theme-controls {top: var(--NormalGap);}
        #bottom-buttons {bottom: var(--NormalGap);}
        
        .light-on {display: var(--LightOn);}
        .light-off {display: var(--LightOff);}
        
        button#scroll-to-top {cursor: default;}
        button#scroll-to-top.visible {cursor: pointer;}
        button#scroll-to-top .ph {color: rgba(var(--Clr-Text),.2);}
        button#scroll-to-top.visible .ph {color: rgba(var(--Clr-Text),1);}
        #credit .ph {width: .95em; height: .95em;}
        
        /* TUMBLR CONTROLS */
        iframe.tmblr-iframe {
            z-index: 999999999!important;
            margin-top: 1em;
            margin-right: 3em;
            opacity: 0;
            visibility: hidden;
            transform:scale(0.7);
            transform-origin:100% 0;
            -webkit-transform:scale(0.7);
            -webkit-transform-origin:100% 0;
            -o-transform:scale(0.7);
            -o-transform-origin:100% 0;
            -moz-transform:scale(0.7);
            -moz-transform-origin:100% 0;
            -ms-transform:scale(0.7);
            -ms-transform-origin:100% 0;
            -webkit-transition: all 0.5s;
            -moz-transition: all 0.5s;
            -ms-transition: all 0.5s;
            -o-transition: all 0.5s;
            transition: all 0.5s;
            filter: var(--TumblrControls);
            -webkit-filter: var(--TumblrControls);
            -o-filter: var(--TumblrControls);
            -moz-filter: var(--TumblrControls);
            -ms-filter: var(--TumblrControls);
        }
        
        body.controls-clicked iframe.tmblr-iframe {
            opacity: 1.0;
            visibility: visible;
        }
        
        /* MAIN CONTAINER */
        main {
            width: var(--Post-Width);
            margin: 50px auto;
            display: grid;
            justify-items: center;
            justify-content: center;
        }
        
        /* HEADER */
        header, nav {
            width: var(--Post-Width);
            background: rgba(var(--Clr-Header),1);
            padding: var(--NormalGap);
            justify-content: center;
        }
        
        header {
            gap: var(--NormalGap);
            border-top: 1px solid rgba(var(--Clr-Borders),1);
            border-left: 1px solid rgba(var(--Clr-Borders),1);
            border-right: 1px solid rgba(var(--Clr-Borders),1);
        }
        
        header img {width: 50px; margin: 5px 0 -3px;}
        img.circle {border-radius: 50%;}
        img.square {border-radius: 0;}
        img.rounded {border-radius: 5px;}
        
        .header-text {
            flex-direction: column;
            text-align: center;
            max-width: calc(100% - var(--NormalGap) * 3 - 75px);
            width: fit-content;
        }
        
        .blog-title {
            position: relative;
            margin-bottom: 10px;
        }
        
        .blog-title::after {
            content: "";
            position: absolute;
            bottom: -5px;
            left: 0;
            background: linear-gradient(90deg in oklch, rgba(var(--Clr-Ac1),1), rgba(var(--Clr-Ac2),1), rgba(var(--Clr-Ac3),1), rgba(var(--Clr-Ac4),1), rgba(var(--Clr-Ac5),1), rgba(var(--Clr-Ac6),1));
            width: 100%;
            height: 2px;
        }
        
        nav {
            justify-content: space-around;
            border-bottom: 1px solid rgba(var(--Clr-Borders),1);
            border-left: 1px solid rgba(var(--Clr-Borders),1);
            border-right: 1px solid rgba(var(--Clr-Borders),1);
            position: sticky;
            top: 0;
            z-index: 999;
        }
        
        nav a:nth-of-type(6n-5) .ph {color: rgba(var(--Clr-Ac1),1);}
        nav a:nth-of-type(6n-4) .ph {color: rgba(var(--Clr-Ac2),1);}
        nav a:nth-of-type(6n-3) .ph {color: rgba(var(--Clr-Ac3),1);}
        nav a:nth-of-type(6n-2) .ph  {color: rgba(var(--Clr-Ac4),1);}
        nav a:nth-of-type(6n-1) .ph  {color: rgba(var(--Clr-Ac5),1);}
        nav a:nth-of-type(6n) .ph  {color: rgba(var(--Clr-Ac6),1);}
        
        nav a:hover .ph {
            color: rgba(var(--Clr-Text),1);
        }
        
        /* POSTS */
        .posts:nth-of-type(6n-5) a, 
        .posts:nth-of-type(6n-5) b, 
        .posts:nth-of-type(6n-5) button {color: rgba(var(--Clr-Ac1),1);}
        
        .posts:nth-of-type(6n-4) a, 
        .posts:nth-of-type(6n-4) b, 
        .posts:nth-of-type(6n-4) button {color: rgba(var(--Clr-Ac2),1);}
        
        .posts:nth-of-type(6n-3) a, 
        .posts:nth-of-type(6n-3) b, 
        .posts:nth-of-type(6n-3) button {color: rgba(var(--Clr-Ac3),1);}
        
        .posts:nth-of-type(6n-2) a, 
        .posts:nth-of-type(6n-2) b, 
        .posts:nth-of-type(6n-2) button {color: rgba(var(--Clr-Ac4),1);}
        
        .posts:nth-of-type(6n-1) a, 
        .posts:nth-of-type(6n-1) b, 
        .posts:nth-of-type(6n-1) button {color: rgba(var(--Clr-Ac5),1);}
        
        .posts:nth-of-type(6n) a, 
        .posts:nth-of-type(6n) b, 
        .posts:nth-of-type(6n) button {color: rgba(var(--Clr-Ac6),1);}
        
        .posts a, .posts button {border-bottom: 1px solid transparent;}
        .posts a:hover, .posts button:hover {color: rgba(var(--Clr-Text),1);}
        
        
        .posts:nth-of-type(6n-5) .post-more a:hover, 
        .posts:nth-of-type(6n-5) .post-header a:hover, 
        .posts:nth-of-type(6n-5) .post-footer a:hover, 
        .posts:nth-of-type(6n-5) button.tags-toggle:hover {
            border-bottom: 1px solid rgba(var(--Clr-Ac1),1);
        }
        
        .posts:nth-of-type(6n-4) .post-more a:hover, 
        .posts:nth-of-type(6n-4) .post-header a:hover, 
        .posts:nth-of-type(6n-4) .post-footer a:hover, 
        .posts:nth-of-type(6n-4) button.tags-toggle:hover {
            border-bottom: 1px solid rgba(var(--Clr-Ac2),1);
        }
        
        .posts:nth-of-type(6n-3) .post-more a:hover, 
        .posts:nth-of-type(6n-3) .post-header a:hover, 
        .posts:nth-of-type(6n-3) .post-footer a:hover, 
        .posts:nth-of-type(6n-3) button.tags-toggle:hover {
            border-bottom: 1px solid rgba(var(--Clr-Ac3),1);
        }
        
        .posts:nth-of-type(6n-2) .post-more a:hover, 
        .posts:nth-of-type(6n-2) .post-header a:hover, 
        .posts:nth-of-type(6n-2) .post-footer a:hover, 
        .posts:nth-of-type(6n-2) button.tags-toggle:hover {
            border-bottom: 1px solid rgba(var(--Clr-Ac4),1);
        }
        
        .posts:nth-of-type(6n-1) .post-more a:hover, 
        .posts:nth-of-type(6n-1) .post-header a:hover, 
        .posts:nth-of-type(6n-1) .post-footer a:hover, 
        .posts:nth-of-type(6n-1) button.tags-toggle:hover {
            border-bottom: 1px solid rgba(var(--Clr-Ac5),1);
        }
        
        .posts:nth-of-type(6n) .post-more a:hover, 
        .posts:nth-of-type(6n) .post-header a:hover, 
        .posts:nth-of-type(6n) .post-footer a:hover, 
        .posts:nth-of-type(6n) button.tags-toggle:hover {
            border-bottom: 1px solid rgba(var(--Clr-Ac6),1);
        }
        
        #post-container {
            margin-top: 50px;
            width: var(--Post-Width);
        }
        
        .posts {
            width: 100%;
            background: rgba(var(--Clr-Posts),1);
            margin-bottom: var(--Post-Margin);
            border: 1px solid rgba(var(--Clr-Borders),1);
            position: relative;
        }
        
        /* POST HEADER */
        .post-header {
            justify-content: space-between;
            gap: 0 var(--SmallGap);
            padding: var(--NormalGap);
            border-bottom: 1px solid rgba(var(--Clr-Borders),1);
        }
        
        .post-header-left, .post-header-right {
            gap: 0 var(--NormalGap);
        }
        
        .post-header-left img {
            width: 40px;
        }
        
        .post-header-text {
            flex-direction: column;
            justify-content: space-evenly;
        }
        
        .date {
            font-size: .9em;
            opacity: .9;
            position: relative;
            margin-left: 10px;
        }
        
        .date::before {
            content: " · ";
            position: absolute;
            left: -8px;
        }
        
        .date a {
            color: rgba(var(--Clr-Text),1)!important;
        }
        
        .pinned .ph {font-size: 1rem; opacity: .9;}
        
        .post-more-click {
            cursor: help;
            width: 30px;
            height: auto;
            aspect-ratio: 1/1;
            padding: 3px 0 0;
            border-radius: 50%;
        }
        
        .post-more-click:hover {
            background: rgba(var(--Clr-Background),1);
        }
        
        .post-more-click svg {
            width: 20px;
            height: 20px;
            fill: rgba(var(--Clr-Text),1);
        }
        
        .turn.active svg {
            transform: rotate(90deg);
            transition: transform 0.4s;
        }
        
        .post-more {
            display: none;
            position: absolute;
            right: 0;
            width: 175px;
            background: rgba(var(--Clr-Posts),1);
            border: 1px solid rgba(var(--Clr-Borders),1);
            margin: -15px -25px 0 0;
            z-index: 99;
            font-size: 0.9em;
        }
        
        .post-more a {
            display: block;
            padding: var(--SmallGap) var(--NormalGap);
            color: rgba(var(--Clr-Text),1)!important;
        }
        
        .post-more a:not(:last-of-type) {
            border-bottom: 1px solid rgba(var(--Clr-Borders),1);
        }
        
        /* POST FOOTER */
        .post-footer {
            justify-content: space-between;
            padding: var(--NormalGap);
        }
        
        .likeb {
            position: relative;
            display: inline-block;
            height: 1.6em;
            margin: 0 0 -1px var(--SmallGap);
        }
        
        .likeb .like_button iframe {
            position: absolute;
            top: 0;
            left: 0;
            bottom: 0;
            right: 0;
            z-index: 2;
            opacity: 0;
        }
        
        .like_button iframe {width: 100% !important; height: 100% !important;}
        .likeb .liked + .actual-button {color: rgba(var(--Clr-Liked),1);}
        .likeb .liked + .actual-button:after {content: 'd'; background: transparent;}
        
        /* TAGS */
        button.tags-toggle {
            font-size: inherit;
            padding: 0;
            margin-right: var(--SmallGap);
        }
        
        button.tags-toggle.hide {
            position: relative;
            padding: 0;
            margin-right: var(--SmallGap);
            font-size: 1em;
        }
        
        button.tags-toggle.hide::before {
            content: "show";
            position: absolute;
            top: 0;
            left: -40px;
            color: inherit;
        }
        
        button.tags-toggle.hide.show::before {
            content: "hide";
            position: absolute;
            top: 0;
            left: -35px;
            color: inherit;
        }
        
        button.tags-toggle > span {
            vertical-align: middle;
        }
        
        .hide {
            display: none;
        }
        
        .hide.show {
            display: inline-block;
        }
        
        .tags {
            {block:IndexPage}
            {block:ifTagsOnToggle}
            display: none;
            {/block:ifTagsOnToggle}
            {/block:IndexPage}
            padding: var(--NormalGap) var(--NormalGap) 0;
        }
        
        .tags a {
            display: inline-block;
            margin: var(--NormalGap) var(--SmallGap) 0 0;
            color: rgba(var(--Clr-Text),1)!important;
            opacity: .8;
        }
        
        .tags a:hover {
            opacity: 1;
        }
        
        .tags a svg {
            width: .9em; height: .9em;
            vertical-align: middle;
            margin-right: 3px;
            fill: rgba(var(--Clr-Text),1)!important;
        }
        
        /* CAPTIONS */
        .caption {
            list-style: none;
            padding: var(--NormalGap);
        }
        
        .reblog-header {
            margin-bottom: var(--NormalGap);
        }
        
        .reblog-header img {
            width: 25px;
            border-radius: 50%;
            border: 2px solid rgba(var(--Clr-Links),1);
            margin: 0 var(--SmallGap) -5px 0;
        }
        
        .reblog-header a {
            font-weight: bold;
        }
        
        /* TEXT + NPF STYLING */
        .text-title {
            padding: var(--SmallGap);
            margin-top: var(--SmallGap);
        }
        
        .text-title, .text-caption h1:first-of-type, .quote, .quote-source, .npf_quote, .link-title, .link-host, a.read_more {
            text-align: center;
        }
        
        .npf_quote, .npf_chat, .chat {
            font-family: inherit!important;
        }
        
        a.read_more {
            display: block;
            width: fit-content;
            margin: 0 auto;
        }
        
        img, img:hover, a:hover img {
            border: none!important;
        }
        
        
        a.poll-row {
            border: none!important;
            border-radius: 2px!important;
        }
        
        a.poll-row:hover {
            color: rgba(var(--Clr-Posts),1)!important;
        }
        
        .posts:nth-of-type(6n-5) a.poll-row {background-color: rgba(var(--Clr-Ac1),1)!important;}
        
        .posts:nth-of-type(6n-4) a.poll-row {background-color: rgba(var(--Clr-Ac2),1)!important;}
        
        .posts:nth-of-type(6n-3) a.poll-row {background-color: rgba(var(--Clr-Ac3),1)!important;}
        
        .posts:nth-of-type(6n-2) a.poll-row {background-color: rgba(var(--Clr-Ac4),1)!important;}
        
        .posts:nth-of-type(6n-1) a.poll-row {background-color: rgba(var(--Clr-Ac5),1)!important;}
        
        .posts:nth-of-type(6n) a.poll-row {background-color: rgba(var(--Clr-Ac6),1)!important;}
        
        /* PHOTOS */
        .legacy-photo img {
            max-width: 100%;
            height: auto;
        }
        
        [photoset-layout] {
            gap: var(--Gutter-Size);
        }
        
        [photoset-layout] img {
            cursor: pointer;
        }
        
        .vignette, #vignette {opacity: 0;}
        .tmblr-lightbox, #tumblr_lightbox {
            background-color: rgba(var(--Clr-Light-Box),.75) !important;
        }
        
        .lightbox-image, #tumblr_lightbox img {
            box-shadow: none !important;
            border-radius: 0 !important;
            max-width: none;
            filter: none;
        }
        
        /* QUOTE */
        .quote, .npf_quote {
            position: relative;
            padding-left: 25px;
        }
        
        .quote::before, .npf_quote::before {
            display: block;
            content: "\e660";
            font-family: "Phosphor" !important;
            speak: never;
            font-style: normal;
            font-weight: normal;
            font-variant: normal;
            text-transform: none;
            line-height: 1;
            letter-spacing: 0;
            
            position: absolute;
            top: .25rem;
            left: 0px;
            width: 1em;
            height: 1em;
            transform: rotate(180deg);
        }
        
        .quote-source {
            margin-top: var(--SmallGap);
        }
        
        /* CHAT POSTS */
        .chat {
            list-style: none;
            margin: 0;
            padding: 0;
        }
        
        .chat li {
            margin: var(--SmallGap) 0;
        }
        
        /* LINK POSTS */
        div.npf-link-block {
            margin: var(--SmallGap) 0;
            border: 1px solid rgba(var(--Clr-Borders),1);
        }
        
        div.npf-link-block:hover {
            border: 1px solid transparent!important;
        }
        
        div.npf-link-block .poster {
            background-position: 50%;
            background-repeat: no-repeat;
            background-size: cover;
            background-clip: content-box;
            border-bottom: 0px!important;
            height: 250px;
            position: relative;
        }
        
        div.npf-link-block .poster::before {
            background: #000;
            content: "";
            display: block;
            height: 100%;
            opacity: .4;
            position: absolute;
            width: 100%;
            transition: all 0.4s;
            -webkit-transition: all 0.4s;
            -moz-transition: all 0.4s;
            -ms-transition: all 0.4s;
            -o-transition: all 0.4s;
        }
        
        div.npf-link-block .title {
            color: #fff;
            font-weight: 400;
            padding: var(--NormalGap);
            position: absolute;
            text-align: center;
        }
        
        div.npf-link-block .bottom {
            background: rgba(var(--Clr-Background),1);
            color: inherit;
            line-height: 1.4;
            padding: var(--NormalGap);
        }
        
        div.npf-link-block .bottom .description {
            color: inherit;
            font-size: inherit;
            line-height: 1.4;
            margin: 0;
            max-height: 50px;
            overflow: hidden;
            overflow-wrap: anywhere;
            text-overflow: ellipsis;
        }
        
        div.npf-link .bottom .site-name {
            color: inherit;
            font-size: 0.9em;
            font-weight: 400;
            line-height: 18px;
            margin-top: var(--SmallGap);
            opacity: .65;
            text-transform: uppercase;
        }
        
        .link-wrap {
            width: calc(100% - var(--NormalGap) * 2);
            background: rgba(var(--Clr-Text),0.025);
            margin: var(--NormalGap) auto;
            border: 1px solid rgba(var(--Clr-Borders),0.15);
            border-radius: var(--SmallGap);
            -webkit-transition: border 0.4s;
            -moz-transition: border 0.4s;
            -ms-transition: border 0.4s;
            -o-transition: border 0.4s;
        }
        
        /* AUDIO POSTS */
        .posts:nth-of-type(6n-5) .custom_audio_buttons [class^="ph"],
        .posts:nth-of-type(6n-5) .track, 
        .posts:nth-of-type(6n-5) .npf-audio-title {
            color: rgba(var(--Clr-Ac1),1);
        }
        
        .posts:nth-of-type(6n-4) .custom_audio_buttons [class^="ph"], 
        .posts:nth-of-type(6n-4) .track, 
        
        .posts:nth-of-type(6n-4) .npf-audio-title {
            color: rgba(var(--Clr-Ac2),1);
        }
        
        .posts:nth-of-type(6n-3) .custom_audio_buttons [class^="ph"], 
        .posts:nth-of-type(6n-3) .track, 
        .posts:nth-of-type(6n-3) .npf-audio-title {
            color: rgba(var(--Clr-Ac3),1);
        }
        
        .posts:nth-of-type(6n-2) .custom_audio_buttons [class^="ph"], 
        .posts:nth-of-type(6n-2) .track, 
        .posts:nth-of-type(6n-2) .npf-audio-title {
            color: rgba(var(--Clr-Ac4),1);
        }
        
        .posts:nth-of-type(6n-1) .custom_audio_buttons [class^="ph"], 
        .posts:nth-of-type(6n-1) .track, 
        .posts:nth-of-type(6n-1) .npf-audio-title {
            color: rgba(var(--Clr-Ac5),1);
        }
        
        .posts:nth-of-type(6n) .custom_audio_buttons [class^="ph"], 
        .posts:nth-of-type(6n) .track, 
        .posts:nth-of-type(6n) .npf-audio-title {
            color: rgba(var(--Clr-Ac6),1);
        }
        
        
        .posts:nth-of-type(6n-5) .npf-audio-wrapper {
            --NPF-Audio-Buttons-Color: rgba(var(--Clr-Ac1),1);
        }
        
        .posts:nth-of-type(6n-4) .npf-audio-wrapper {
            --NPF-Audio-Buttons-Color: rgba(var(--Clr-Ac2),1);
        }
        
        .posts:nth-of-type(6n-3) .npf-audio-wrapper {
            --NPF-Audio-Buttons-Color: rgba(var(--Clr-Ac3),1);
        }
        
        .posts:nth-of-type(6n-2) .npf-audio-wrapper {
            --NPF-Audio-Buttons-Color: rgba(var(--Clr-Ac4),1);
        }
        
        .posts:nth-of-type(6n-1) .npf-audio-wrapper {
            --NPF-Audio-Buttons-Color: rgba(var(--Clr-Ac5),1);
        }
        
        .posts:nth-of-type(6n) .npf-audio-wrapper {
            --NPF-Audio-Buttons-Color: rgba(var(--Clr-Ac6),1);
        }
        
        
        
        
        .audio_wrap, .npf-audio-wrapper {
            /*width: calc(100% - var(--NormalGap) * 2);*/
            margin: var(--NormalGap) auto;
            background: rgba(var(--Clr-Text),0.025);
        }
        
        .audio_wrap {
            padding: var(--NormalGap) var(--NormalGap) var(--NormalGap) var(--SmallGap);
            gap: 0 var(--NormalGap);
        }
        
        .custom_audio_buttons {height: 1.25em;}
        .custom_audio_error_icon {color: #f05e5e;}
        
        .custom_audio_buttons [class^="ph"] {
            font-size: 22px;
        }
        
        .audio_info {
            margin-left: var(--SmallGap);
            width: calc(100% - 100px - var(--NormalGap));
        }
        
        .audio_info p {margin : var(--ExSmallGap) 0;}
        
        .audio_info .track, .npf-audio-title {
            font-weight: bold;
        }
        
        .album-art, .npf-audio-image {
            width: 70px;
        }
        
        .npf-audio-wrapper {
            --NPF-Audio-Buttons-Size: 1.25em;
            --NPF-Audio-Buttons-Spacing: 1.3rem;
            --NPF-Audio-Image-Size: 80px;
            margin-bottom: var(--SmallGap);
        }
        
        .npf-audio-background {
            width: calc(var(--NPF-Audio-Image-Size) + var(--NormalGap));
            padding: var(--NormalGap);
        }
        
        iframe[src*='open.spotify.com'][src*='track'], figure[data-npf*='open.spotify.com'][data-npf*='track']{height:80px!important; width:100%!important;}
        iframe.soundcloud_audio_player {height: 150px!important; width: 100%!important;}
        
        .tumblr_video_container, .tmblr-full > video {
            width: 100%!important;
            height: auto!important;
        }
        
        /* ASK POSTS */
        .asker-wrap {
            width: calc(100% - 2em);
            margin: var(--NormalGap) auto 0;
            background: rgba(var(--Clr-Text),0.025);
            border: 1px solid rgba(var(--Clr-Borders),0.15);
            padding: var(--NormalGap);
        }
        
        .asker, .answerer-text {
            gap: var(--NormalGap);
        }
        
        .asker img, .answerer-text img {
            width: 40px;
            border-radius: 50%;
        }
        
        .asker-text span {
            display: block;
        }
        
        .question p:first-of-type, .answerp:last-of-type {
            margin-top: 0;
        }
        
        .question p:last-of-type, .answer p:last-of-type {
            margin-bottom: 0;
        }
        
        .question, .answer {
            margin-top: var(--SmallGap) 0 0;
            padding: var(--SmallGap) 0;
        }
        
        .replies {
            padding: var(--SmallGap) var(--NormalGap);
        }
        
        .answerer-wrap {
            padding: var(--NormalGap);
        }
        
        /* POST NOTES */
        #post-notes {
            width: 100%;
            background: rgba(var(--Clr-Posts), 1);
            margin-bottom: var(--Post-Margin);
            border: 1px solid rgba(var(--Clr-Borders), 1);
        }
        
        #post-notes h1.note-title {
            margin: 0;
            padding: var(--SmallGap) var(--NormalGap);
            border-bottom: 1px solid rgba(var(--Clr-Borders), 1);
        }
        
        #post-notes img {
            display: none;
        }
        
        #post-notes ol {
            list-style: none;
            padding: 0 var(--NormalGap);
        }
        
        #post-notes li {
            margin: var(--SmallGap) 0;
            padding: 0;
        }
        
        #post-notes a {
            color: rgba(var(--Clr-Ac1),1);
        }
        
        /* PAGE NAVIGATION */
        #pagination {
            gap: 0 var(--NormalGap);
            margin: -25px auto 25px;
            justify-content: center;
            background: rgba(var(--Clr-Posts), 1);
            padding: var(--NormalGap);
            border: 1px solid rgba(var(--Clr-Borders), 1);
        }
        
        #pagination a {
            color: rgba(var(--Clr-Text),.8);
        }
        
        #pagination a:hover {
            color: rgba(var(--Clr-Text),1);
        }
        
        /* RESPONSIVE */
        @media only screen and (max-width: 600px) {
            :root {
                --Post-Width: 80vw;
            }
        }
        
        {CustomCSS}
    </style>
</head>
<body>
    <div id="theme-controls" class="flex align-center">
        <button id="controls-click" title="Tumblr Controls" aria-label="toggle tumblr controls">
            <i class="ph ph-gear-six"></i>
        </button>
        
        <button id="theme-toggle" aria-label="toggle light or dark mode">
            <i class="ph ph-sun light-on" title="Light's On"></i>
            <i class="ph ph-moon light-off" title="Light's Off"></i>
        </button>
    </div>
    
    <div id="bottom-buttons" class="flex align-center">
        <button id="scroll-to-top" title="scroll to top">
            <i class="ph ph-caret-up"></i>
        </button>
        
        <button id="credit"><a href="https://enbythemes.tumblr.com" title="That's so Gay theme by Rou">
            <i class="ph ph-diamond"></i>
        </a></button>
    </div>
    
    <main>
        <!-- HEADER -->
        <header class="flex align-center">
            <!--<img src="https://i.imgur.com/KZDpmJR.jpeg" class="{select:icons shape}" alt="Header icon">-->
            <img src="https://i.imgur.com/KZDpmJR.jpeg" class="{select:icons shape}" alt="Header icon">
            
            <div class="header-text flex">
                <div class="blog-title">
                    {text:custom blog title}
                </div>
                
                <div class="blog-subtitle">
                    {text:custom description}
                </div>
            </div>
        </header>
        
        <nav class="flex align-center" aria-label="navigation">
            <a href="{BlogURL}" title="refresh"><i class="ph ph-house"></i></a>
            <a href="/ask" title="ask"><i class="ph ph-envelope"></i></a>
            <a href="{text:link one url}" title="{text:link one}"><i class="ph ph-{text:link one icon}"></i></a>
            <a href="{text:link two url}" title="{text:link two}"><i class="ph ph-{text:link two icon}"></i></a>
            <a href="{text:link three url}" title="{text:link three}"><i class="ph ph-{text:link three icon}"></i></a>
            <a href="{text:link four url}" title="{text:link four}"><i class="ph ph-{text:link four icon}"></i></a>
        </nav>
        
        <!-- POSTS -->
        <section id="post-container">
            {block:Posts inlineMediaWidth="1280" inlineNestedMediaWidth="1280"}
            <!-- {block:NoRebloggedFrom}
            {block:RebloggedFrom}{ReblogParentName}{/block:RebloggedFrom}
            {/block:NoRebloggedFrom} -->
            {block:ContentSource}<!-- {SourceURL}
            {block:SourceLogo}<img src="{BlackLogoURL}"width="{LogoWidth}" height="{LogoHeight}" alt="{SourceTitle}" />{/block:SourceLogo}
            {block:NoSourceLogo}{SourceLink}{/block:NoSourceLogo} -->
            {/block:ContentSource}
            <article class="posts" id="{PostID}" post-type="{PostType}">
                <!-- POST HEADER -->
                {block:Date}
                <div class="post-header flex align-center">
                   <div class="post-header-left flex">
                   {block:RebloggedFrom}
                   <img src="{ReblogParentPortraitURL-128}" class="reblogged-icon {select:icons shape}" alt="{ReblogParentName}'s icon">
                   {/block:RebloggedFrom}
                   
                   {block:NotReblog}
                   <img src="{PortraitURL-128}" class="{select:icons shape}" alt="{Name}'s icon">
                   {/block:NotReblog}
                   
                   <div class="post-header-text flex">
                       <div class="who">
                           {block:RebloggedFrom}
                           <!--<i class="ph ph-repeat"></i>-->
                           <a href="{ReblogParentURL}">{ReblogParentName}</a>
                           {/block:RebloggedFrom}
                           
                           {block:NotReblog}
                           <!--<i class="ph ph-info"></i>-->
                           <a href="{Permalink}">Orignal Post</a>
                           {/block:NotReblog}
                       </div>
                       
                       <div class="date">
                           <a href="{Permalink}" class="time-ago">
                               {Timestamp}
                           </a>
                       </div>
                   </div> 
                    </div>
                    
                    <div class="post-header-right flex align-center">
                        {block:PinnedPostLabel}
                        <span class="pinned" title="Pinned post">
                            <i class="ph ph-map-pin"></i>
                        </span>
                        {/block:PinnedPostLabel}
                        
                        <button class="post-more-click turn" title="More info">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#000000" viewBox="0 0 256 256"><path d="M140,128a12,12,0,1,1-12-12A12,12,0,0,1,140,128Zm56-12a12,12,0,1,0,12,12A12,12,0,0,0,196,116ZM60,116a12,12,0,1,0,12,12A12,12,0,0,0,60,116Z"></path></svg>
                        </button>
                    </div>
                </div>
                
                <!-- MORE POST INFO -->
                <div class="post-more">
                    <a href="{Permalink}">
                        {Month} {DayofMonth}{DayofMonthSuffix}, {Year}
                    </a>
                    
                    {block:NotReblog}
                    <a href="{Permalink}">
                        Original
                    </a>
                    {/block:NotReblog}
                    
                    {block:RebloggedFrom}
                    <a href="{ReblogParentURL}">
                        View previous reblog
                    </a>
                    
                    <a href="{ReblogRootURL}">
                        Original
                    </a>
                    {/block:RebloggedFrom}
                    
                    {block:ContentSource}
                    <a href="{SourceURL}">{lang:Source}</a>
                    {/block:ContentSource}
                </div>
                {/block:Date}
                
                <!-- TEXT POSTS -->
                {block:Text}
                {block:Title}
                <div class="text-title">
                    {Title}
                </div>
                {/block:Title}
                
                {block:NotReblog}
                <li class="caption text-caption">
                  {Body}
                </li>
                {/block:NotReblog}
                
                {block:RebloggedFrom}
                {block:Reblogs}
                <li class="caption text-caption">
                    <div class="reblog-header {block:IsOriginalEntry}original{/block:IsOriginalEntry} flex align-center">
                        <a href="{permalink}" target="_blank" {block:isdeactivated}class="inactive"{/block:isdeactivated}>
                            {username}
                        </a>
                    </div>
                    {Body}
                </li>
                {/block:Reblogs}
                {/block:RebloggedFrom}
                {/block:Text}
                
                <!-- (LEGACY) PHOTO POSTS -->
                {block:Photo}
                  <div class="legacy-photo">
                    {LinkOpenTag}<a href="#" onclick="Tumblr.Lightbox.init([{ width: {PhotoWidth-HighRes}, height: {PhotoHeight-HighRes}, low_res: '{PhotoURL-500}', high_res: '{PhotoURL-HighRes}' }]); $('body').toggleClass('tumblr_lightbox_active'); return false"><img src="{PhotoURL-HighRes}" alt="{PhotoAlt}"></a>{LinkCloseTag}
                  </div>
                {/block:Photo}
                
                <!-- (LEGACY) PHOTOSET POSTS -->
                {block:Photoset}
                  <div class="photoset-grid" photoset-layout="{PhotosetLayout}">{block:Photos}<div data-width="{PhotoWidth-HighRes}" data-height="{PhotoHeight-HighRes}" data-lowres="{PhotoURL-500}" data-highres="{PhotoURL-HighRes}" onclick="lightbox(this)"><img src="{PhotoURL-HighRes}" /></div>{/block:Photos}</div>
                {/block:Photoset}
                
                <!-- QUOTE POSTS -->
                {block:Quote}
                <div class="caption">
                    <div class="quote">{Quote}</div>
                    <div class="quote-source">{Source}</div>
                </div>
                {/block:Quote}
                
                <!-- CHAT POSTS -->
                {block:Chat}
                  <ul class="chat caption">
                      {block:Lines}
                        <li>
                          {block:Label}{Label}{/block:Label} 
                          {Line}
                        </li>
                      {/block:Lines}
                  </ul>
                {/block:Chat}
                
                <!-- LINK POSTS -->
                {block:Link}
                <div class="npf-link-block flex centered {block:Thumbnail}has-poster{/block:Thumbnail}">
                    <a href="{URL}">
                        {block:Thumbnail}
                        <div class="poster flex centered" style="background-image: url({Thumbnail-HighRes})">
                            <div class="title">
                                {Name}
                            </div>
                        </div>
                        {/block:Thumbnail}
                        
                        <div class="bottom">
                            <div class="description">{Description}</div>
                            <div class="site-name">{Host}</div>
                        </div>
                    </a>
                </div>
                {/block:Link}
                
                <!-- ANSWER POSTS -->
                {block:Answer}
                <div class="ask-wrap">
                    <div class="asker-wrap">
                        <div class="asker flex align-center">
                            <img src="{AskerPortraitURL-128}" alt="asker icon">
                            <div class="asker-text">
                                <span class="asker-name">{Asker}</span>
                                <span>sent a message</span>
                            </div>
                        </div>
                        
                        <div class="question">
                            {Question}
                        </div>
                    </div>
                    
                    {block:NotReblog}
                      <div class="replies">
                        {Replies}
                      </div>
                    {/block:NotReblog}
                    
                    {block:Answerer}
                    <div class="answerer-wrap">
                        {block:RebloggedFrom}
                        
                        <div class="answerer-text">
                            {Answerer} replied
                        </div>
                        
                        <div class="answer">
                            {Answer}
                        </div>
                        
                        {/block:RebloggedFrom}
                    </div>
                    {/block:Answerer}
                </div>
                {/block:Answer}
                
    <!-- AUDIO POSTS -->
                {block:Audio}
                <div class="audio_wrap flex align-center">
                    {block:AudioPlayer}
                    {AudioPlayer}
                    <div class="audio_player">
                        <span class="custom_audio_buttons"></span>
                        <div class="custom_audio_seekbar"></div>
                    </div>
                    
                    <div class="audio_info">
                        {block:TrackName}<p class="track">{TrackName}</p>{/block:TrackName}
                        {block:Artist}<p class="artist">{Artist}</p>{/block:Artist}
                    </div>
                    
                    {block:AlbumArt}
                    <img src="{AlbumArtURL}" class="album-art" alt="Album art">
                    {/block:AlbumArt}
                    
                    {/block:AudioPlayer}
                </div>
                {/block:Audio}
                
    <!-- VIDEO POSTS -->
                {block:Video}
                <div class="video">
                    {Video-700}
                </div>
                {/block:Video}
                
    <!-- CAPTIONS -->
                {block:Caption}
                <div class="caption {block:notreblog} original-post {/block:notreblog}">
                    
                    {block:Link}
                        {block:Description}
                        {block:NotReblog}{Description}{/block:NotReblog}
                        {/block:Description}
                    {/block:Link}
                    
                    {block:notreblog}
                    {block:caption}{Caption}{/block:caption}
                    {/block:notreblog}
                    
                    {block:Rebloggedfrom}
                        {block:Reblogs}
                        <div class="reblogs" {block:Quote}style="display:none;"{/block:Quote}>
                            <div class="reblog-header {block:IsOriginalEntry}original{/block:IsOriginalEntry} flex align-center">
                                <a href="{permalink}" target="_blank" {block:isdeactivated}class="inactive"{/block:isdeactivated}>
                                    {username}
                                </a>
                            </div>
                            
                            <div class="reblog-content">
                                {Body}
                            </div>
                        </div>
                        {/block:Reblogs}
                    {/block:RebloggedFrom}
                </div>
                {/block:Caption}
                
                
                
                
                <!-- TAGS -->
                {block:HasTags}
